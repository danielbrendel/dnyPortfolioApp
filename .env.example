# Asatru PHP - App environment configuration file
# 
# Scheme:
#   name=value
# Example
#   APP_NAME="My App name"
# Datatypes:
#   string, integer, float, boolean and null (auto detected)

# App settings
APP_NAME="Portfolio Homepage"
APP_VERSION=1.0
APP_AUTHOR="Daniel Brendel"
APP_CONTACT="dbrendel1988@gmail.com"
APP_DESCRIPTION="Senior Indie Software Developer & Project Founder"
APP_TITLE="${APP_AUTHOR} | ${APP_DESCRIPTION}"
APP_SLOGAN="Scientia potentia est"
APP_DEBUG=true
APP_BASEDIR=""
APP_TIMEZONE=null
APP_ADMIN_ACCESS_TOKEN=""
APP_ENABLE_BLOG=false
APP_ALLOW_BLOG_HTML=false
APP_CACHE_DURATION=125

